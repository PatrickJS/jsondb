{
  "name": "json-fixture-db",
  "version": "0.1.0",
  "description": "A local JSON fixture database with schema inference, generated TypeScript types, and a small runtime API.",
  "type": "module",
  "bin": {
    "jsondb": "./src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./schema": {
      "types": "./src/schema.d.ts",
      "default": "./src/schema-builders.js"
    },
    "./client": {
      "types": "./src/index.d.ts",
      "default": "./src/client.js"
    }
  },
  "files": [
    "src/**/*.js",
    "src/**/*.d.ts",
    "!src/**/*.test.js",
    "scripts",
    "examples/*/README.md",
    "examples/*/db/**",
    "examples/*/jsondb.config.mjs",
    "examples/*/src/generated/**",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "check": "node ./scripts/check-syntax.js",
    "test": "node ./scripts/run-tests.js",
    "examples": "node ./scripts/serve-examples.js",
    "view:examples": "node ./scripts/serve-examples.js",
    "jsondb": "node ./src/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
